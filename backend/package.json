{
  "name": "@stockbroker/backend",
  "description": "Financial expert LangGraph.js example",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx @langchain/langgraph-cli dev",
    "build": "tsc --project tsconfig.json --outDir dist",
    "start": "npx @langchain/langgraph-cli dev",
    "deps:check": "npx taze major -f",
    "deps:update": "npx taze major -f -w && pnpm install",
    "deps:update:no-install": "npx taze major -f -w"
  },
  "author": "Brace Sproul",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.26",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/openai": "^1.2.8",
    "@langchain/tavily": "^1.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "dotenv": "^16.6.1",
    "typescript": "^5.9.3"
  }
}
