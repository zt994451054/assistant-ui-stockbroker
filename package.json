{
  "name": "@stockbroker/root",
  "private": true,
  "version": "0.0.0",
  "author": "Brace Sproul & Simon Farshid",
  "license": "MIT",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "pnpm turbo run build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "deps:check": "npx taze major --force",
    "deps:check:repo": "turbo run deps:check",
    "deps:update": "npx taze major --force --write && pnpm install",
    "deps:update:repo": "npx taze major --force --write && turbo run deps:update:no-install && pnpm install",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@stockbroker/frontend",
    "dev:backend": "turbo run dev --filter=@stockbroker/backend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "turbo": "^2.8.9"
  },
  "packageManager": "pnpm@10.30.0"
}
