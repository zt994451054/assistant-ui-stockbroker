{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["**/dist/**", "**/.next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deps:check": {
      "cache": false
    },
    "deps:update": {
      "cache": false
    },
    "deps:update:no-install": {
      "cache": false
    }
  }
}
